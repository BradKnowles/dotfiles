{
	"chat.commandCenter.enabled": false,
	"chat.detectParticipant.enabled": false,

	"conventionalCommits.autoCommit": false,
	"conventionalCommits.emojiFormat": "emoji",

	"diffEditor.ignoreTrimWhitespace": false,
	"diffEditor.experimental.showMoves": true,

	"editor.fontFamily": "CommitMonoDark Nerd Font, Consolas, 'Courier New', monospace",
	"editor.fontLigatures": true,
	"editor.minimap.enabled": false,
	"editor.renderWhitespace": "all",

	"extensions.ignoreRecommendations": true,

	"git.enableCommitSigning": true,
	"gpgIndicator.enablePassphraseCache": true,

	"terminal.integrated.cursorBlinking": true,
	"terminal.integrated.cursorStyle": "underline",
	"terminal.integrated.drawBoldTextInBrightColors": false,
	"terminal.integrated.gpuAcceleration": "on",
	"terminal.integrated.fontFamily": "CommitMonoDark Nerd Font",
	"terminal.integrated.fontLigatures.enabled": true,
	"terminal.integrated.lineHeight": 1.05,

	"update.enableWindowsBackgroundUpdates": false,
	"update.mode": "manual",

	"window.zoomPerWindow": false,
	"window.zoomLevel": 0.5,

	"workbench.colorCustomizations": {
		"terminal.background": "#282C34",
		"terminal.ansiBlack": "#0C0C0C",
		"terminal.ansiBlue": "#1E5BFF",
		"terminal.ansiBrightBlack": "#5A6374",
		"terminal.ansiBrightBlue": "#6699FF",
		"terminal.ansiBrightCyan": "#00FFFF",
		"terminal.ansiBrightGreen": "#99CC66",
		"terminal.ansiBrightMagenta": "#DDA0DD",
		"terminal.ansiBrightRed": "#CC6666",
		"terminal.ansiBrightWhite": "#FFFFFF",
		"terminal.ansiBrightYellow": "#E5C07B",
		"terminalCursor.foreground": "#FFFFFF",
		"terminal.ansiCyan": "#00CED1",
		"terminal.foreground": "#CCCCCC",
		"terminal.ansiGreen": "#009900",
		"terminal.ansiMagenta": "#C678DD",
		"terminal.ansiRed": "#CC0033",
		"terminal.selectionBackground": "#FFFFFF",
		"terminal.ansiWhite": "#DFDFDF",
		"terminal.ansiYellow": "#C19C00"
	},
	"workbench.colorTheme": "Dark+",
	"workbench.editor.enablePreview": false,
	"workbench.iconTheme": "vscode-icons",
}
